      D[Lifecycle<br/>lifecycle.py]
      E[Role Map<br/>YAML]
      F[Okta Client<br/>okta_client.py]
      G[Provider interface]
      H[SlackProvider<br/>mock]
      I[GoogleWorkspaceProvider<br/>mock]
      J[Structured JSON logs]
    end

    C --> D
    D --> E
    D --> F
    D --> G
    G --> H
    G --> I
    D --> J

    F -->|HTTPS<br/>SSWS token| K[(Okta Tenant)]
    H -.mock.-> L[(Slack)]
    I -.mock.-> M[(Google Workspace)]
