# ---- Okta Management API (for lifecycle CLI) ----
# Your developer tenant, e.g. https://dev-12345678.okta.com
OKTA_ORG_URL=https://dev-XXXXXXXX.okta.com
# API token created in Okta Admin -> Security -> API -> Tokens
OKTA_API_TOKEN=00xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Okta OIDC (for the Flask login demo) ----
# From an OIDC "Web Application" you create in Okta Admin -> Applications
OIDC_CLIENT_ID=0oaxxxxxxxxxxxxxxxxx
OIDC_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OIDC_ISSUER=https://dev-XXXXXXXX.okta.com/oauth2/default
OIDC_REDIRECT_URI=http://localhost:5000/authorization-code/callback

# ---- Slack (optional; leave blank to run SlackProvider in mock mode) ----
# Bot User OAuth Token from api.slack.com/apps -> OAuth & Permissions.
# Required scopes: users:read, users:read.email, channels:read,
# channels:manage, groups:write, chat:write.
SLACK_BOT_TOKEN=

# ---- App behavior ----
FLASK_SECRET_KEY=change-me-to-a-random-string
LOG_LEVEL=INFO
